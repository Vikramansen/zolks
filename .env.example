# Resend (https://resend.com) — create an API key and verify a sending domain for production.
RESEND_API_KEY=re_xxxxxxxx

# Where waitlist notifications are delivered (your inbox).
WAITLIST_TO_EMAIL=you@yourdomain.com

# Optional. Must use a domain you verified in Resend. Defaults to Resend's test sender.
# EMAIL_FROM=Zolks <notifications@yourdomain.com>

# Optional. Set to "true" to also email the person who signed up with a short confirmation.
# SEND_WAITLIST_CONFIRMATION=false
